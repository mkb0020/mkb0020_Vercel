{
  "version": 2,
  "functions": {
    "index.py": {
      "runtime": "python3.12"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ],
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    }
  ],
  "installCommand": "pip install -r requirements.txt"
}